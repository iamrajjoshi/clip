{
  "name": "clip.rajjoshi.me",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "pnpm --filter @clip/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "check": "pnpm --filter @clip/web check && pnpm --filter @clip/cli typecheck",
    "clip": "pnpm --filter @clip/cli clip",
    "install:cli": "pnpm link --global ./packages/clip-cli"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
